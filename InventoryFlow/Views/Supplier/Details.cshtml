@model Supplier
@{ ViewData["Title"] = Model.Name; }

<div class="inv-card p-4 inv-form-card">
    <div class="d-flex justify-content-between align-items-start">
        <div>
            <h4 class="mb-0">@Model.Name</h4>
            <div class="text-inv-muted">@Model.ContactPerson</div>
        </div>
        @if (Model.IsActive)
        {
            <span class="badge badge-inv-ok">Active</span>
        }
        else
        {
            <span class="badge badge-inv-out">Inactive</span>
        }
    </div>
    <hr />
    <dl class="row mb-0">
        <dt class="col-sm-3">Phone</dt><dd class="col-sm-9">@Model.Phone</dd>
        <dt class="col-sm-3">Email</dt><dd class="col-sm-9">@Model.Email</dd>
        <dt class="col-sm-3">Address</dt><dd class="col-sm-9">@Model.Address</dd>
        <dt class="col-sm-3">Supplies</dt><dd class="col-sm-9">@Model.ProductsSupplied</dd>
        <dt class="col-sm-3">Added On</dt><dd class="col-sm-9">@Model.CreatedAt.ToString("dd MMM yyyy")</dd>
    </dl>
    <div class="mt-3">
        <a asp-action="Edit" asp-route-id="@Model.SupplierId" class="btn btn-outline-inv">Edit</a>
        <a asp-action="Index" class="btn btn-outline-secondary">Back to List</a>
    </div>
</div>
