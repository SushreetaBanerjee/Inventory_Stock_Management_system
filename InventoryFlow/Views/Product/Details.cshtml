@model Product
@{ ViewData["Title"] = Model.Name; }

<div class="row g-3">
    <div class="col-lg-8">
        <div class="inv-card p-4">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <h4 class="mb-0">@Model.Name</h4>
                    <div class="text-inv-muted">@Model.SKU &middot; @(Model.Category?.Name ?? "Uncategorized")</div>
                </div>
                @if (Model.CurrentStock == 0)
                {
                    <span class="badge badge-inv-out fs-6">Out of Stock</span>
                }
                else if (Model.IsLowStock)
                {
                    <span class="badge badge-inv-low fs-6">Low Stock</span>
                }
                else
                {
                    <span class="badge badge-inv-ok fs-6">In Stock</span>
                }
            </div>

            <hr />
            <div class="row g-3">
                <div class="col-6 col-md-3">
                    <div class="text-inv-muted small">Current Stock</div>
                    <div class="fw-semibold fs-5">@Model.CurrentStock @Model.UnitOfMeasure</div>
                </div>
                <div class="col-6 col-md-3">
                    <div class="text-inv-muted small">Reorder Threshold</div>
                    <div class="fw-semibold fs-5">@Model.ReorderThreshold</div>
                </div>
                <div class="col-6 col-md-3">
                    <div class="text-inv-muted small">Cost Price</div>
                    <div class="fw-semibold fs-5">₹@Model.CostPrice.ToString("N2")</div>
                </div>
                <div class="col-6 col-md-3">
                    <div class="text-inv-muted small">Selling Price</div>
                    <div class="fw-semibold fs-5">₹@Model.SellingPrice.ToString("N2")</div>
                </div>
            </div>

            <hr />
            <div class="text-inv-muted small mb-1">Stock Level</div>
            @{
                var pct = Model.ReorderThreshold > 0 ? Math.Min(100, (int)((double)Model.CurrentStock / (Model.ReorderThreshold * 3) * 100)) : (Model.CurrentStock > 0 ? 100 : 0);
                var barClass = Model.CurrentStock == 0 ? "is-out" : (Model.IsLowStock ? "is-low" : "");
            }
            <div class="stock-bar-track" style="height:12px;">
                <div class="stock-bar-fill @barClass" style="width:@(pct)%;"></div>
            </div>

            <div class="mt-4 d-flex gap-2">
                <a asp-controller="Stock" asp-action="In" asp-route-productId="@Model.ProductId" class="btn btn-inv-primary"><i class="bi bi-box-arrow-in-down"></i> Stock In</a>
                <a asp-controller="Stock" asp-action="Out" asp-route-productId="@Model.ProductId" class="btn btn-outline-inv"><i class="bi bi-box-arrow-up"></i> Stock Out</a>
                <a asp-controller="Stock" asp-action="History" asp-route-productId="@Model.ProductId" class="btn btn-outline-secondary"><i class="bi bi-clock-history"></i> Movement History</a>
                <a asp-action="Edit" asp-route-id="@Model.ProductId" class="btn btn-outline-secondary"><i class="bi bi-pencil"></i> Edit</a>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="inv-card p-4">
            <h6 class="section-title">Primary Supplier</h6>
            @if (Model.Supplier != null)
            {
                <div class="fw-semibold">@Model.Supplier.Name</div>
                <div class="text-inv-muted small">@Model.Supplier.ContactPerson</div>
                <div class="text-inv-muted small">@Model.Supplier.Phone</div>
            }
            else
            {
                <p class="text-inv-muted mb-0">No supplier linked.</p>
            }
        </div>
    </div>
</div>
